# Cổng chạy ứng dụng (Mặc định: 5000)
PORT=5000

# Chuỗi kết nối CSDL MySQL (Railway/Render Online hoặc Localhost)
# Định dạng: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/keophui_db"

# Khóa bí mật dùng để mã hóa và xác thực phiên đăng nhập (JWT)
# Bạn nên tạo chuỗi ngẫu nhiên dài và bảo mật
JWT_SECRET="keophui_jwt_secret_production_2026_secure"

# Định danh Google OAuth Client ID dùng để xác thực Google Sign-In
# Nhận từ Google Cloud Console (Credentials)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# Địa chỉ URL của Frontend dùng để lọc CORS bảo mật
# Thay thế bằng link Vercel thực tế của bạn
FRONTEND_URL="https://keophui-app.vercel.app"
